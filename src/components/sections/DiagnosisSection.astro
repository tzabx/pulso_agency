---
import Badge from '../common/Badge.astro';
import SectionShell from '../layout/SectionShell.astro';

interface Props {
  id?: string;
  badge: string;
  titleLines: string[];
  description: string;
  callout: string;
}

const { id, badge, titleLines, description, callout } = Astro.props;
---

<SectionShell id={id} tone="dark">
  <div class="mx-auto max-w-4xl text-center">
    <div class="reveal">
      <Badge label={badge} tone="dark" className="mb-6" />
      <h2 class="text-4xl font-bold leading-tight text-brand-cream md:text-5xl">
        {titleLines.map((line) => (
          <>
            {line}
            <br />
          </>
        ))}
      </h2>
      <p class="mx-auto mt-6 max-w-3xl text-base leading-relaxed text-brand-light md:text-lg">{description}</p>
      <div class="mx-auto mt-6 max-w-2xl rounded-2xl border-l-4 border-brand-mint bg-brand-mint/10 px-6 py-5 text-left text-base font-medium leading-relaxed text-brand-cream">
        {callout}
      </div>
    </div>
  </div>
</SectionShell>
