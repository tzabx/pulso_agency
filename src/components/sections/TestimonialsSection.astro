---
import CardGrid from '../common/CardGrid.astro';
import SectionHeader from '../common/SectionHeader.astro';
import SectionShell from '../layout/SectionShell.astro';
import TestimonialCard from '../cards/TestimonialCard.astro';

interface TestimonialItem {
  initials: string;
  quote: string;
  name: string;
  role: string;
}

interface Props {
  id?: string;
  badge: string;
  title: string;
  highlight: string;
  items: TestimonialItem[];
}

const { id, badge, title, highlight, items } = Astro.props;
---

<SectionShell id={id}>
  <SectionHeader badge={badge} title={title} highlight={highlight} className="reveal mb-12" />
  <CardGrid columns={3}>
    {items.map((item) => (
      <div class="reveal">
        <TestimonialCard {...item} />
      </div>
    ))}
  </CardGrid>
</SectionShell>
