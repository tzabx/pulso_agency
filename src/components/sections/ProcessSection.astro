---
import CardGrid from '../common/CardGrid.astro';
import SectionHeader from '../common/SectionHeader.astro';
import SectionShell from '../layout/SectionShell.astro';
import StepCard from '../cards/StepCard.astro';

interface StepItem {
  number: string;
  title: string;
  description: string;
}

interface Props {
  id?: string;
  badge: string;
  title: string;
  highlight: string;
  description: string;
  steps: StepItem[];
}

const { id, badge, title, highlight, description, steps } = Astro.props;
---

<SectionShell id={id} tone="soft">
  <SectionHeader badge={badge} title={title} highlight={highlight} description={description} className="reveal mb-12" />
  <CardGrid columns={4}>
    {steps.map((step) => (
      <div class="reveal">
        <StepCard {...step} />
      </div>
    ))}
  </CardGrid>
</SectionShell>
