---
import BaseCard from '../common/BaseCard.astro';
import Checklist from '../common/Checklist.astro';
import MediaFrame from '../common/MediaFrame.astro';

interface Props {
  number: string;
  title: string;
  description: string;
  body: string;
  checklist: string[];
  image: {
    src: string;
    alt: string;
  };
}

const { number, title, description, body, checklist, image } = Astro.props;
---

<div class="grid overflow-hidden rounded-4xl bg-white shadow-soft transition hover:-translate-y-1 md:grid-cols-[280px_1fr]">
  <BaseCard tone="dark" className="rounded-none bg-brand-dark">
    <div class="flex h-full flex-col justify-between">
      <div>
        <div class="text-5xl font-bold text-gradient">{number}</div>
        <h3 class="mt-2 text-2xl font-bold text-white">{title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-brand-light">{description}</p>
      </div>
    </div>
  </BaseCard>
  <div class="p-8">
    <p class="mb-5 text-sm leading-relaxed text-brand-mid md:text-[0.95rem]">{body}</p>
    <Checklist items={checklist} className="mb-6" />
    <MediaFrame src={image.src} alt={image.alt} className="rounded-3xl" imageClassName="max-h-[320px]" />
  </div>
</div>
