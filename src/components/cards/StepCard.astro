---
import BaseCard from '../common/BaseCard.astro';

interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<BaseCard className="h-full transition hover:-translate-y-1">
  <div class="mb-3 text-4xl font-bold text-gradient">{number}</div>
  <h3 class="text-lg font-bold text-brand-dark">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-brand-mid">{description}</p>
</BaseCard>
