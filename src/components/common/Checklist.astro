---
interface Props {
  items: string[];
  tone?: 'light' | 'dark';
  className?: string;
}

const { items, tone = 'light', className = '' } = Astro.props;
const textClass = tone === 'dark' ? 'text-brand-light' : 'text-brand-mid';
---

<ul class:list={['grid gap-x-4 gap-y-2 text-sm sm:grid-cols-2', textClass, className]}>
  {items.map((item) => (
    <li class="flex items-start gap-2 leading-relaxed">
      <span class="mt-[2px] text-brand-mint">✓</span>
      <span>{item}</span>
    </li>
  ))}
</ul>
