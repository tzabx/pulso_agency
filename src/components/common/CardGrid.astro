---
interface Props {
  columns?: 1 | 2 | 3 | 4;
  className?: string;
}

const { columns = 3, className = '' } = Astro.props;
const columnClass = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-4',
}[columns];
---

<div class:list={['grid gap-6', columnClass, className]}>
  <slot />
</div>
