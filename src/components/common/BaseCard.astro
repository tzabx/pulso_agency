---
interface Props {
  tone?: 'light' | 'dark' | 'glass';
  className?: string;
}

const { tone = 'light', className = '' } = Astro.props;
const toneClass = {
  light: 'bg-white text-brand-dark shadow-soft',
  dark: 'bg-brand-dark text-white',
  glass: 'border border-white/5 bg-white/5 text-brand-cream',
}[tone];
---

<article class:list={['rounded-4xl p-8', toneClass, className]}>
  <slot />
</article>
