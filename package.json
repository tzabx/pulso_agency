{
  "name": "pulso-agency",
  "version": "1.0.0",
  "description": "Landing de Pulso Inteligente Agency en Astro y Tailwind CSS",
  "scripts": {
    "test": "echo \"No test suite configured\"",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "dev:astro": "astro dev",
    "build:astro": "astro build",
    "dev:react": "npm --prefix react_app run dev",
    "build:react": "npm --prefix react_app run build",
    "sync:db": "node scripts/sync-db.js",
    "export:db": "node scripts/export-db.js",
    "server": "npm run sync:db && json-server --watch db.json --port 3001",
    "dev:react:server": "npm run sync:db && concurrently \"npm run server\" \"npm run dev:react\"",
    "dev:all": "npm run sync:db && concurrently \"npm run server\" \"npm run dev:astro\" \"npm run dev:react\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/tailwind": "^5.1.4",
    "astro": "^5.18.1",
    "tailwindcss": "^3.4.19"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "json-server": "^1.0.0-beta.15"
  }
}
